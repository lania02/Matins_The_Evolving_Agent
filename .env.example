# Copy this file to `.env` and fill in your real values. `.env` is gitignored.
# Matins loads `.env` automatically at startup (see matins/config.py:load_dotenv).
#
# The variable NAME must match `provider.api_key_env` in config.yaml.
# For Gemini via the OpenAI-compatible endpoint, this is your Google AI Studio key.
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram bot token — only if messaging.channel = telegram.
# Must match messaging.telegram.bot_token_env in config.yaml.
MATINS_TELEGRAM_TOKEN=your-telegram-bot-token-here
